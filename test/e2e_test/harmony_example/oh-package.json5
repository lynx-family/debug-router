{
  "name": "debug_router",
  "license": "Apache-2.0",
  "devDependencies": {},
  "repository": "https://github.com/lynx-family/debug-router",
  "author": "lynx",
  "description": "A Connector for Debug",
  "scripts": {
    "prepare": "python3 ./script/build.py --sync --verbose",
    "dev": "python3 ./script/build.py --is_debug --verbose",
    "build": "python3 ./script/build.py --is_debug --build_hap --sync --verbose",
    "build:release": "python3 ./script/build.py --build_hap --sync --verbose",
  },
  "version": "0.0.1",
  "dependencies": {
  },
  "dynamicDependencies": {},
  "parameterFile": "./parameter.json",
  "overrides": {
    "@lynx/debug_router": "file:./debug_router",
  },
  "modelVersion": "5.0.0"
}
